    "next": "15.5.18",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "query-string": "^9.2.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
